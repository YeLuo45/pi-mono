# Studio 服务端（复制为 .env 后按需填写；勿提交 .env）
STUDIO_PORT=8787
STUDIO_HOST=127.0.0.1
# 仓库根（默认 process.cwd()）
# STUDIO_REPO_ROOT=

# OpenAI 兼容上游（Ollama 示例）
STUDIO_UPSTREAM_BASE_URL=http://127.0.0.1:11434/v1

# 可选：事件日志路径（默认 <repo>/studio_events.jsonl）
# STUDIO_LOG_PATH=

# 图像生成（OpenAI 兼容 images/generations；可与 STUDIO_IMAGE_API_KEY 或云端 provider 密钥共用）
# STUDIO_IMAGE_BASE_URL=https://api.openai.com/v1
# STUDIO_IMAGE_MODEL=dall-e-2
# STUDIO_IMAGE_API_KEY=

# 调试代理时打印已脱敏头（0/1）
# STUDIO_DEBUG_PROXY_HEADERS=0

# 可选：ffmpeg 可执行文件路径（视频转码）
# FFMPEG_PATH=
